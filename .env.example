# ===========================================
# QRIS Payment Gateway Configuration
# ===========================================

# QRIS Static String (from your QRIS provider)
QRIS_STATIC_STRING=00020101021126360009...

# Merchant Info
QRIS_MERCHANT_NAME=Your Store Name
QRIS_EXPIRY_MINUTES=20

# QRIS Suffix Range
QRIS_SUFFIX_MIN=1
QRIS_SUFFIX_MAX=999

# ===========================================
# QRIS Interactive Provider
# https://merchant.qris.interactive.co.id
# ===========================================
MUTATION_COLLECTOR_ENABLED=true
QRIS_INTERACTIVE_EMAIL=your@email.com
QRIS_INTERACTIVE_PASSWORD=your-password
QRIS_LOOKBACK_DAYS=1

# Security (REQUIRED in production)
PAYMENT_WEBHOOK_SECRET=your-webhook-hmac-secret
HASH_PEPPER=random-pepper-for-mutation-hashing

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# SSE
SSE_MAX_CONNECTIONS_PER_USER=3

# Development
NODE_ENV=development
DEBUG=false

# Database
DATABASE_PATH=./payments.db

# Logging
LOG_LEVEL=info
